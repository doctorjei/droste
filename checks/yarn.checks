@quiet seed.checks
@quiet lint.checks
@quiet fiber.checks
@quiet thread.checks
@quiet sheet.checks

# Kernel-dependent (yarn additions)
lvm2 available	test -x /usr/sbin/lvm
thin_check available	command -v thin_check
nbd-client available	test -x /usr/sbin/nbd-client
quota available	command -v quota
lspci available	command -v lspci
hdparm available	test -x /usr/sbin/hdparm
dmidecode available	test -x /usr/sbin/dmidecode
brctl available	test -x /usr/sbin/brctl
