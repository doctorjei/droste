@quiet seed.checks
@quiet lint.checks
@quiet fiber.checks
@quiet thread.checks
@quiet sheet.checks
@quiet yarn.checks
@quiet page.checks

# Kernel-dependent (fabric additions)
drbdadm available	command -v drbdadm
sbd available	command -v sbd
dlm_controld available	command -v dlm_controld
iscsiadm available	test -x /usr/sbin/iscsiadm
targetcli available	command -v targetcli
multipath available	test -x /usr/sbin/multipathd
