ARG BASE_IMAGE=droste-bar
FROM ${BASE_IMAGE}

LABEL description="droste-foo: OCI-LXC bootable system container (seed equivalent)"

# droste-foo adds back the LXC-specific packages that were stripped
# from droste-bar. The result is equivalent to a seed rootfs and can
# boot as a system container (systemd as PID 1) via droste-oci-hook.sh.

COPY oci/seed-oci-exclude.txt /tmp/seed-oci-exclude.txt
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       $(grep -v '^#' /tmp/seed-oci-exclude.txt | grep -v '^$') \
    && rm -f /tmp/seed-oci-exclude.txt \
    && rm -rf /var/lib/apt/lists/*

CMD ["/sbin/init"]
