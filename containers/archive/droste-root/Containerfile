FROM debian:trixie-slim

LABEL maintainer="droste" \
      description="droste-root: OCI seed base (unified base across VM/LXC/OCI)"

# ── Strip documentation ──────────────────────────────────────────
RUN printf '%s\n' \
      'path-exclude /usr/share/doc/*' \
      'path-exclude /usr/share/man/*' \
      'path-exclude /usr/share/info/*' \
      'path-exclude /usr/share/locale/*' \
      'path-include /usr/share/locale/locale.alias' \
      'path-include /usr/share/locale/en*' \
      'path-include /usr/share/locale/zh*' \
      'path-include /usr/share/locale/hi*' \
      'path-include /usr/share/locale/es*' \
      'path-include /usr/share/locale/ar*' \
      'path-include /usr/share/locale/fr*' \
      'path-include /usr/share/locale/bn*' \
      'path-include /usr/share/locale/pt*' \
      'path-include /usr/share/locale/id*' \
      'path-include /usr/share/locale/ur*' \
      'path-include /usr/share/locale/de*' \
      'path-include /usr/share/locale/ja*' \
      'path-include /usr/share/locale/ko*' \
      > /etc/dpkg/dpkg.cfg.d/01-nodoc \
    && rm -rf /usr/share/doc/* /usr/share/man/* /usr/share/info/*

# ── Seed base packages (unified base across VM/LXC/OCI) ─────────
# Installs packages from seed-target.txt minus OCI-impossible packages.
# This establishes the same foundation as the LXC seed and VM genericcloud.
# See oci/seed-oci-exclude.txt for the exclusion list and rationale.
COPY lxc/seed-target.txt /tmp/seed-target.txt
COPY oci/seed-oci-exclude.txt /tmp/seed-oci-exclude.txt
RUN grep -v '^#' /tmp/seed-target.txt | grep -v '^$' | sort > /tmp/seed-all.txt \
    && grep -v '^#' /tmp/seed-oci-exclude.txt | grep -v '^$' | sort > /tmp/exclude.txt \
    && comm -23 /tmp/seed-all.txt /tmp/exclude.txt > /tmp/seed-oci.txt \
    && apt-get update \
    && apt-get install -y --no-install-recommends $(cat /tmp/seed-oci.txt) \
    && rm -f /tmp/seed-target.txt /tmp/seed-oci-exclude.txt \
           /tmp/seed-all.txt /tmp/exclude.txt /tmp/seed-oci.txt \
    && rm -rf /var/lib/apt/lists/*

# ── Locales ──────────────────────────────────────────────────────
RUN sed -i '/^# .*UTF-8/{ \
      /en_US\|zh_CN\|zh_TW\|hi_IN\|es_ES\|ar_SA\|fr_FR\|bn_IN\|pt_BR\|pt_PT\|id_ID\|ur_PK\|de_DE\|ja_JP\|ko_KR/s/^# // \
    }' /etc/locale.gen \
    && locale-gen

# ── Droste user ──────────────────────────────────────────────────
RUN groupadd -g 1000 droste \
    && useradd -u 1000 -g droste -m -s /bin/bash droste \
    && echo 'droste:droste' | chpasswd \
    && printf 'droste ALL=(ALL) NOPASSWD:ALL\n' > /etc/sudoers.d/droste \
    && chmod 0440 /etc/sudoers.d/droste

# ── Sysctl (written but not applied — container kernel is shared) ─
RUN printf 'net.ipv4.ip_forward = 1\nnet.ipv6.conf.all.forwarding = 1\n' \
      > /etc/sysctl.d/99-droste.conf

USER droste
WORKDIR /home/droste
CMD ["/bin/bash"]
