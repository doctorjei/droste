ARG BASE_IMAGE=droste-seed
FROM ${BASE_IMAGE}

LABEL description="droste-seed-lxc: bootable system container base (seed equivalent)"

# Adds back the LXC-specific packages that were stripped from droste-bar
# (systemd, dbus, udev, cloud-init, etc.). The result is equivalent to
# a seed rootfs and can boot as a system container (systemd PID 1) via kento.

COPY oci/seed-oci-exclude.txt /tmp/seed-oci-exclude.txt
RUN apt-get -qq update \
    && apt-get -qq install -y --no-install-recommends \
       $(grep -v '^#' /tmp/seed-oci-exclude.txt | grep -v '^$') \
    && rm -f /tmp/seed-oci-exclude.txt \
    && rm -rf /var/lib/apt/lists/*

CMD ["/sbin/init"]
