#!/usr/bin/env bash
# Build, test, and manage droste OCI images.
#
# Usage:
#   scripts/drostify build fiber              # build fiber OCI
#   scripts/drostify build all --force        # rebuild all tiers
#   scripts/drostify test sheet               # test sheet OCI
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

trap 'echo ""; echo "--- drostify finished at $(date "+%Y-%m-%d %H:%M:%S") ---"' EXIT

# ── Globals ─────────────────────────────────────────────────────────
declare -A FORCE_TIERS=()
VERBOSE=false

# ── Tier name registry ──────────────────────────────────────────────
# Index-aligned: LAYER_APP[i], LAYER_SYS[i], LAYER_VM[i] are siblings.
# Parent chain: app[0] → app[1] → ... → app[6] (process containers)
#               sys[i] is the system container child of app[i]
#               vm[i] is the VM-bootable child of sys[i]
#
# To rename tiers, change ONLY these three arrays. Everything else
# (tier lists, parent mappings, parsers, help text) derives from them.
LAYER_APP=(seed  fiber   sheet  page    tome      press    gutenberg)
LAYER_SYS=(lint  thread  yarn   fabric  tapestry  loom     jacquard)
LAYER_VM=(root   hair    wool   felt    amimono   stuffer  stuffinator)

# ── Derived tier arrays ─────────────────────────────────────────────
ALL_OCI_APP_TIERS=("${LAYER_APP[@]}")
ALL_OCI_SYS_TIERS=("${LAYER_SYS[@]}")
ALL_OCI_VM_TIERS=("${LAYER_VM[@]}")

# Interleaved build order: app[i], sys[i], vm[i] for each layer.
# This is also the correct dependency order and downstream order.
ALL_OCI_TIERS=()
for _i in "${!LAYER_APP[@]}"; do
    ALL_OCI_TIERS+=("${LAYER_APP[$_i]}" "${LAYER_SYS[$_i]}" "${LAYER_VM[$_i]}")
done
unset _i

# ── Tier helpers ────────────────────────────────────────────────────
is_oci_tier() {
    case "$1" in app-all|sys-all|vm-all) return 0 ;; esac
    local t
    for t in "${ALL_OCI_TIERS[@]}"; do
        [[ "$t" == "$1" ]] && return 0
    done
    return 1
}

is_leaf_tier() {
    local tier="$1" t
    for t in "${LAYER_SYS[@]}" "${LAYER_VM[@]}"; do
        [[ "$t" == "$tier" ]] && return 0
    done
    return 1
}

# Return the parent tier for a given OCI tier.
oci_parent() {
    local tier="$1"
    local i
    for i in "${!LAYER_APP[@]}"; do
        if [[ "$tier" == "${LAYER_APP[$i]}" ]]; then
            [[ $i -gt 0 ]] && echo "${LAYER_APP[$((i-1))]}" || echo ""
            return
        fi
        if [[ "$tier" == "${LAYER_SYS[$i]}" ]]; then
            echo "${LAYER_APP[$i]}"
            return
        fi
        if [[ "$tier" == "${LAYER_VM[$i]}" ]]; then
            echo "${LAYER_SYS[$i]}"
            return
        fi
    done
}

detect_container_cmd() {
    if command -v podman &>/dev/null; then
        echo podman
    elif command -v docker &>/dev/null; then
        echo docker
    else
        echo "Error: neither podman nor docker found" >&2
        exit 1
    fi
}

# ── Usage ───────────────────────────────────────────────────────────
usage() {
    cat <<EOF
Usage: $(basename "$0") [COMMAND] [IMAGE] [OPTIONS]

Build and test droste OCI images.

Commands:
  build      Build the image(s)
  test       Run smoke tests on existing image(s)
  oci        Build/test OCI container images (explicit prefix)
  build-all  Build all OCI images
  help       Show this help message

Images (OCI):
EOF
    # Generate tier list from arrays
    local i
    for i in "${!LAYER_APP[@]}"; do
        printf "  %-14s Process container (layer %d)\n" "${LAYER_APP[$i]}" "$i"
        printf "  %-14s System container (kento)\n" "${LAYER_SYS[$i]}"
        printf "  %-14s VM-bootable (kento VM mode)\n" "${LAYER_VM[$i]}"
    done
    cat <<EOF
  app-all      All app/process containers
  sys-all      All system containers
  vm-all       All VM-bootable containers
  all          All OCI tiers (app + sys + vm)

Options:
  --force            Rebuild named tier(s) even if images exist
  --force-cascade    Rebuild named tier(s) and all downstream dependents
  --verbose          Show full build output (builds are quiet by default)
  --debug            Alias for --verbose

Examples:
  $(basename "$0") build ${LAYER_APP[1]}              # build ${LAYER_APP[1]} OCI
  $(basename "$0") build ${LAYER_SYS[1]}          # build bootable ${LAYER_SYS[1]} for kento
  $(basename "$0") test ${LAYER_APP[2]}               # test ${LAYER_APP[2]} OCI
  $(basename "$0") oci build ${LAYER_APP[1]}           # explicit OCI prefix
  $(basename "$0") oci build all            # build all OCI tiers
  $(basename "$0") oci build app-all        # build all app/process containers
  $(basename "$0") oci build sys-all        # build all system containers
  $(basename "$0") oci build ${LAYER_APP[2]} --force-cascade  # rebuild ${LAYER_APP[2]} + all downstream
  $(basename "$0") build-all               # build all OCI images
  $(basename "$0") build-all --force       # rebuild everything
EOF
}

# ── OCI test ────────────────────────────────────────────────────────
do_test_oci() {
    local tier="$1"
    local image="droste-${tier}"
    local checkfile="$PROJECT_DIR/checks/${tier}.checks"
    local container_cmd
    container_cmd=$(detect_container_cmd)

    if [[ ! -f "$checkfile" ]]; then
        echo "Warning: no check file found: $checkfile" >&2
        return 0
    fi

    echo "droste-${tier} OCI test"
    echo "======================"
    echo ""

    local cname="droste-test-${tier}"
    $container_cmd rm -f "$cname" &>/dev/null || true
    $container_cmd run -d --name "$cname" "$image" sleep infinity >/dev/null

    local pass=0 fail=0 errors=()

    # Run @quiet inherited check files (failures only)
    while IFS= read -r line; do
        [[ "$line" =~ ^@quiet\  ]] || continue
        local qfile="${line#@quiet }"
        qfile="$PROJECT_DIR/checks/$qfile"
        [[ -f "$qfile" ]] || { echo "Warning: quiet file not found: $qfile" >&2; continue; }
        while IFS= read -r qline; do
            [[ -z "$qline" ]] && continue
            [[ "$qline" =~ ^# ]] && continue
            [[ "$qline" =~ ^@ ]] && continue
            IFS=$'\t' read -r desc cmd flag <<< "$qline"
            if $container_cmd exec "$cname" bash -c "$cmd" &>/dev/null; then
                pass=$((pass + 1))
            else
                echo "  - FAIL (${qfile##*/}): $desc"
                errors+=("(${qfile##*/}) $desc")
                fail=$((fail + 1))
            fi
        done < <(sed '/@stop/,$d' "$qfile")
    done < "$checkfile"

    # Run this file's own tests verbosely (skip directives)
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        [[ "$line" =~ ^@ ]] && continue
        if [[ "$line" =~ ^#\  ]]; then
            echo "${line#\# }:"
            continue
        fi
        IFS=$'\t' read -r desc cmd flag <<< "$line"
        if $container_cmd exec "$cname" bash -c "$cmd" &>/dev/null; then
            echo "  + $desc"
            pass=$((pass + 1))
        else
            echo "  - FAIL: $desc"
            errors+=("$desc")
            fail=$((fail + 1))
        fi
    done < "$checkfile"

    $container_cmd rm -f "$cname" >/dev/null

    echo ""
    echo "================================"
    echo "Results: ${pass} passed, ${fail} failed"

    if [[ ${fail} -gt 0 ]]; then
        echo ""
        echo "Failures:"
        for err in "${errors[@]}"; do
            echo "  - $err"
        done
        return 1
    fi
}

# ── OCI build ───────────────────────────────────────────────────────
do_build_oci() {
    local tier="$1"
    local container_cmd
    container_cmd=$(detect_container_cmd)

    # Skip if image exists and tier is not forced
    if [[ -z "${FORCE_TIERS[$tier]+x}" ]]; then
        if $container_cmd image exists "droste-${tier}" 2>/dev/null; then
            echo "droste-${tier}: exists, skipping (use --force to rebuild)"
            return 0
        fi
    fi

    # seed is built by build-seed.sh (chroot + import), not a Containerfile
    if [[ "$tier" == "${LAYER_APP[0]}" ]]; then
        echo "Building droste-${tier} (via build-seed.sh)..."
        echo ""
        "$PROJECT_DIR/containers/droste-${tier}/build-seed.sh"
        echo ""
        do_test_oci "$tier"
        return
    fi

    # Map tier → parent image for BASE_IMAGE arg
    local parent
    parent=$(oci_parent "$tier")

    echo "Building droste-${tier} container..."
    echo ""

    local build_args=()
    if [[ -n "$parent" ]]; then
        build_args+=(--build-arg "BASE_IMAGE=localhost/droste-${parent}")
    fi

    if [[ "$VERBOSE" == true ]]; then
        $container_cmd build \
            "${build_args[@]}" \
            -t "droste-${tier}" \
            -f "$PROJECT_DIR/containers/droste-${tier}/Containerfile" \
            "$PROJECT_DIR"
    else
        local logfile
        logfile=$(mktemp /tmp/droste-build-XXXXXX.log)
        set -o pipefail
        if $container_cmd build \
            "${build_args[@]}" \
            -t "droste-${tier}" \
            -f "$PROJECT_DIR/containers/droste-${tier}/Containerfile" \
            "$PROJECT_DIR" 2>&1 | tee "$logfile" \
            | grep --line-buffered -E '^STEP |^COMMIT |^Successfully '; then
            rm -f "$logfile"
        else
            echo ""
            echo "Build failed. Full output:"
            cat "$logfile"
            rm -f "$logfile"
            return 1
        fi
        set +o pipefail
    fi

    echo ""
    echo "Build complete."
    $container_cmd image inspect "droste-${tier}" --format '{{.Size}}' | \
        awk '{printf "Image size: %.0f MB\n", $1/1024/1024}'
    echo ""
    do_test_oci "$tier"
}

# ── OCI tier resolution ────────────────────────────────────────────
# Return dependency chain: all ancestors from seed through target.
resolve_oci_deps() {
    local target="$1"
    local chain=()
    local current="$target"
    # Walk up the parent chain
    while [[ -n "$current" ]]; do
        chain=("$current" "${chain[@]}")
        current=$(oci_parent "$current")
    done
    echo "${chain[@]}"
}

# Return target tier + all downstream dependents.
resolve_oci_downstream() {
    local from="$1"
    # sys and vm tiers are leaves — nothing depends on them
    if is_leaf_tier "$from"; then
        echo "$from"
        return
    fi
    local found=false
    for tier in "${ALL_OCI_TIERS[@]}"; do
        [[ "$tier" == "$from" ]] && found=true
        [[ "$found" == true ]] && echo "$tier"
    done
}

# Return tiers to build for a target (dependency order).
resolve_oci_tiers() {
    local target="$1"
    case "$target" in
        all)     echo "${ALL_OCI_TIERS[@]}" ;;
        app-all) echo "${ALL_OCI_APP_TIERS[@]}" ;;
        sys-all) echo "${ALL_OCI_SYS_TIERS[@]}" ;;
        vm-all)  echo "${ALL_OCI_VM_TIERS[@]}" ;;
        *)       resolve_oci_deps "$target" ;;
    esac
}

# Return tiers to build for a force-cascade: deps + downstream.
resolve_oci_cascade_list() {
    local target="$1"
    local -A include
    local t
    for t in $(resolve_oci_deps "$target"); do include["$t"]=1; done
    for t in $(resolve_oci_downstream "$target"); do include["$t"]=1; done
    for tier in "${ALL_OCI_TIERS[@]}"; do
        [[ -n "${include[$tier]+x}" ]] && echo "$tier"
    done
}

# ── OCI command handler ────────────────────────────────────────────
do_oci_command() {
    local sub_cmd="all"
    local oci_image="all"
    local force=false
    local force_cascade=false

    # Parse: oci [build|test|all] [tier] [--force] [--force-cascade]
    if [[ $# -gt 0 ]]; then
        case "$1" in
            build|test|all) sub_cmd="$1"; shift ;;
            *)
                if is_oci_tier "$1"; then
                    oci_image="$1"; shift
                fi
                ;;
        esac
    fi
    if [[ $# -gt 0 ]]; then
        if is_oci_tier "$1" || [[ "$1" == "all" ]]; then
            oci_image="$1"; shift
        fi
    fi
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force)          force=true; shift ;;
            --force-cascade)  force_cascade=true; force=true; shift ;;
            --verbose|--debug) VERBOSE=true; shift ;;
            *) echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
        esac
    done

    local container_cmd
    container_cmd=$(detect_container_cmd)
    echo "Using container engine: $container_cmd"

    # Compute build list and force set
    local tiers
    if [[ "$sub_cmd" == "build" || "$sub_cmd" == "all" ]]; then
        if [[ "$force_cascade" == true && "$oci_image" != "all" && "$oci_image" != "app-all" && "$oci_image" != "sys-all" && "$oci_image" != "vm-all" ]]; then
            tiers=$(resolve_oci_cascade_list "$oci_image")
            for t in $(resolve_oci_downstream "$oci_image"); do
                FORCE_TIERS["$t"]=1
            done
        elif [[ "$force" == true ]]; then
            tiers=$(resolve_oci_tiers "$oci_image")
            for t in $tiers; do
                FORCE_TIERS["$t"]=1
            done
        else
            tiers=$(resolve_oci_tiers "$oci_image")
        fi
    fi

    case "$sub_cmd" in
        build|all)
            for tier in $tiers; do
                echo ""
                do_build_oci "$tier"
            done
            ;;
        test)
            for tier in $(resolve_oci_tiers "$oci_image"); do
                echo ""
                do_test_oci "$tier"
            done
            ;;
    esac
}

# ── Build-all command handler ────────────────────────────────────
do_build_all_command() {
    local force=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force)          force=true; shift ;;
            --force-cascade)  force=true; shift ;;
            --verbose|--debug) VERBOSE=true; shift ;;
            *)                echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
        esac
    done

    # Mark all tiers as forced if requested
    if [[ "$force" == true ]]; then
        for t in "${ALL_OCI_TIERS[@]}"; do FORCE_TIERS["$t"]=1; done
    fi

    echo "=== Building all OCI images ==="
    echo ""

    local container_cmd
    container_cmd=$(detect_container_cmd)
    echo "Using container engine: $container_cmd"

    for tier in "${ALL_OCI_TIERS[@]}"; do
        echo ""
        do_build_oci "$tier"
    done
}

# ── Parse command and image ──────────────────────────────────────────
COMMAND="build"
IMAGE="all"
FORCE=false
FORCE_CASCADE=false

if [[ $# -gt 0 ]]; then
    case "$1" in
        oci)
            shift
            do_oci_command "$@"
            exit 0
            ;;
        build-all)
            shift
            do_build_all_command "$@"
            exit 0
            ;;
        build|test|help|-h|--help)
            COMMAND="$1"
            shift
            ;;
        *)
            if is_oci_tier "$1" || [[ "$1" == "all" ]]; then
                IMAGE="$1"
                shift
            else
                echo "Unknown argument: $1" >&2
                usage >&2
                exit 1
            fi
            ;;
    esac
fi

if [[ $# -gt 0 ]]; then
    if is_oci_tier "$1" || [[ "$1" == "all" ]]; then
        IMAGE="$1"
        shift
    fi
fi

# ── Parse global options ─────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
    case "$1" in
        --force)          FORCE=true; shift ;;
        --force-cascade)  FORCE_CASCADE=true; FORCE=true; shift ;;
        --verbose|--debug) VERBOSE=true; shift ;;
        *)                echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
    esac
done

# ── Populate FORCE_TIERS ─────────────────────────────────────────────
if [[ "$FORCE_CASCADE" == true && "$IMAGE" != "all" && "$IMAGE" != "app-all" && "$IMAGE" != "sys-all" && "$IMAGE" != "vm-all" ]]; then
    for t in $(resolve_oci_downstream "$IMAGE"); do
        FORCE_TIERS["$t"]=1
    done
elif [[ "$FORCE" == true ]]; then
    case "$IMAGE" in
        all|app-all|sys-all|vm-all)
            for t in $(resolve_oci_tiers "$IMAGE"); do FORCE_TIERS["$t"]=1; done
            ;;
        *)
            FORCE_TIERS["$IMAGE"]=1
            ;;
    esac
fi

# ── Main ────────────────────────────────────────────────────────────
case "$COMMAND" in
    build)
        tiers=$(if [[ "$FORCE_CASCADE" == true ]]; then resolve_oci_cascade_list "$IMAGE"; else resolve_oci_tiers "$IMAGE"; fi)
        for tier in $tiers; do
            echo ""
            do_build_oci "$tier"
        done
        ;;
    test)
        for tier in $(resolve_oci_tiers "$IMAGE"); do
            echo ""
            do_test_oci "$tier"
        done
        ;;
    help|-h|--help)
        usage
        ;;
    *)
        echo "Unknown command: $COMMAND" >&2
        usage >&2
        exit 1
        ;;
esac
