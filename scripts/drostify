#!/usr/bin/env bash
# Build, test, and manage droste images.
#
# Usage:
#   scripts/drostify                            # build and test droste-thread
#   scripts/drostify build thread               # just build droste-thread
#   scripts/drostify test yarn                  # boot and smoke test droste-yarn
#   scripts/drostify build all --force          # rebuild all tiers
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

trap 'echo ""; echo "--- drostify finished at $(date "+%Y-%m-%d %H:%M:%S") ---"' EXIT

# ── Usage ───────────────────────────────────────────────────────────
usage() {
    cat <<EOF
Usage: $(basename "$0") [COMMAND] [IMAGE] [OPTIONS]

Build and test droste images.

Commands:
  prereqs    Check build host prerequisites
  build      Build the image(s) with Packer (or container engine)
  test       Boot existing image(s) and run smoke tests
  all        Prereqs + build + test (default)
  vm         Build/test VM images (explicit prefix)
  container  Build/test container images (podman/docker)
  lxc        Build/test LXC rootfs images (chroot + systemd-nspawn)
  help       Show this help message

Images (VM):
  thread     Container-ready base image (default)
  yarn       VM-capable image (builds on top of thread)
  fabric     HA/storage/cluster image (builds on top of yarn)
  tapestry   Testing/benchmarking/security image (builds on top of fabric)
  loom       Development/build toolchain image (builds on top of tapestry)
  jacquard   Proxmox VE testing environment (builds on top of loom)
  all        All tiers

Images (container):
  fiber      Container base (thread equivalent)
  sheet      VM tooling layer (yarn equivalent)
  page       HA/cluster layer (fabric equivalent)
  tome       Testing/security layer (tapestry equivalent)
  gutenberg  Dev toolchain (loom equivalent)

Images (LXC):
  hair       LXC base (thread equivalent)
  wool       VM tooling layer (yarn equivalent)
  felt       HA/cluster layer (fabric equivalent)
  amimono    Testing/security layer (tapestry equivalent)
  embellisher Dev toolchain (loom equivalent)

Bare tier names are auto-detected — no overlap between VM, container, and LXC names.

Options:
  --force          Overwrite existing images (required for 'build all')
  --ssh-key FILE   Path to SSH public key (default: auto-detect)
  --ssh-port PORT  Host port for SSH (default: 2222)

Examples:
  $(basename "$0")                          # build and test thread (default)
  $(basename "$0") build thread             # just build thread
  $(basename "$0") test yarn                # smoke test yarn
  $(basename "$0") test all                 # smoke test all tiers
  $(basename "$0") build all --force        # build all tiers (overwrite)
  $(basename "$0") test yarn --ssh-key ~/.ssh/id_ed25519.pub
  $(basename "$0") build fiber              # build fiber container (auto-detected)
  $(basename "$0") test sheet               # test sheet container (auto-detected)
  $(basename "$0") vm build thread          # explicit VM prefix
  $(basename "$0") vm test yarn             # explicit VM prefix
  $(basename "$0") container build fiber    # explicit container prefix
  $(basename "$0") container test sheet     # explicit container prefix
  $(basename "$0") container build all      # build all containers
  $(basename "$0") lxc build hair           # build hair LXC rootfs
  $(basename "$0") lxc test hair            # test hair LXC rootfs
  $(basename "$0") build hair               # build hair (auto-detected as LXC)
EOF
}

# ── Prereqs ─────────────────────────────────────────────────────────
do_prereqs() {
    echo "Checking prerequisites..."
    echo ""
    "$SCRIPT_DIR/check-prereqs.sh"
}

# ── Test (uses global SSH_KEY, SSH_PORT) ─────────────────────────────
do_test() {
    local image_type="$1"

    local image
    case "$image_type" in
        thread)   image="$PROJECT_DIR/output-droste-thread/droste-thread.qcow2" ;;
        yarn)     image="$PROJECT_DIR/output-droste-yarn/droste-yarn.qcow2" ;;
        fabric)   image="$PROJECT_DIR/output-droste-fabric/droste-fabric.qcow2" ;;
        tapestry) image="$PROJECT_DIR/output-droste-tapestry/droste-tapestry.qcow2" ;;
        loom)     image="$PROJECT_DIR/output-droste-loom/droste-loom.qcow2" ;;
        jacquard) image="$PROJECT_DIR/output-droste-jacquard/droste-jacquard.qcow2" ;;
    esac

    if [[ ! -f "$image" ]]; then
        echo "Error: image not found at $image" >&2
        echo "Run '$(basename "$0") build $image_type' first." >&2
        exit 1
    fi

    local private_key="${SSH_KEY%.pub}"
    if [[ ! -f "$private_key" ]]; then
        echo "Error: private key not found: $private_key" >&2
        exit 1
    fi

    echo "Booting image for smoke test..."
    echo ""

    # Kill any stale QEMU from a previous run
    local work_dir="${XDG_CACHE_HOME:-$HOME/.cache}/droste-boot"
    local pidfile="${work_dir}/droste.pid"
    if [[ -f "$pidfile" ]]; then
        kill "$(cat "$pidfile")" 2>/dev/null || true
        rm -f "$pidfile"
    fi
    rm -f "${work_dir}/droste-ephemeral.qcow2"

    # Boot in background
    "$SCRIPT_DIR/boot-droste.sh" \
        --ssh-key "$SSH_KEY" \
        --ssh-port "$SSH_PORT" \
        --image "$image" \
        --daemonize

    # Wait for SSH to become available
    echo "Waiting for SSH..."
    local retries=30
    while ! ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
              -o LogLevel=ERROR -o ConnectTimeout=2 \
              -p "$SSH_PORT" -i "$private_key" droste@localhost true &>/dev/null; do
        ((retries--))
        if [[ $retries -le 0 ]]; then
            echo "Error: SSH did not become available" >&2
            exit 1
        fi
        sleep 2
    done
    echo "SSH is up."
    echo ""

    # Run smoke tests for this tier
    "$SCRIPT_DIR/ssh-smoke-test.sh" \
        --port "$SSH_PORT" \
        --ssh-key "$private_key" \
        "$PROJECT_DIR/checks/${image_type}.checks"

    # Clean up — kill QEMU
    pidfile="${XDG_CACHE_HOME:-$HOME/.cache}/droste-boot/droste.pid"
    if [[ -f "$pidfile" ]]; then
        kill "$(cat "$pidfile")" 2>/dev/null || true
        rm -f "$pidfile"
    fi

    echo ""
    echo "Test complete. VM stopped."
}

# ── Build functions ──────────────────────────────────────────────────
# Every build function runs SSH tests immediately after building.

do_build_thread() {
    echo "Building droste-thread image..."
    echo ""

    cd "$PROJECT_DIR/packer/droste-thread"
    packer init .
    packer build -force droste-thread.pkr.hcl

    echo ""
    echo "Build complete."
    ls -lh "$PROJECT_DIR/output-droste-thread/droste-thread.qcow2"
    echo ""
    do_test thread
}

do_build_yarn() {
    echo "Building droste-yarn image (on top of droste-thread)..."
    echo ""

    local base_image="$PROJECT_DIR/output-droste-thread/droste-thread.qcow2"
    cd "$PROJECT_DIR/packer/droste-yarn"
    packer init .
    packer build -force -var "base_image=$base_image" droste-yarn.pkr.hcl

    echo ""
    echo "Build complete."
    ls -lh "$PROJECT_DIR/output-droste-yarn/droste-yarn.qcow2"
    echo ""
    do_test yarn
}

do_build_fabric() {
    echo "Building droste-fabric image (on top of droste-yarn)..."
    echo ""

    local base_image="$PROJECT_DIR/output-droste-yarn/droste-yarn.qcow2"
    cd "$PROJECT_DIR/packer/droste-fabric"
    packer init .
    packer build -force -var "base_image=$base_image" droste-fabric.pkr.hcl

    echo ""
    echo "Build complete."
    ls -lh "$PROJECT_DIR/output-droste-fabric/droste-fabric.qcow2"
    echo ""
    do_test fabric
}

do_build_tapestry() {
    echo "Building droste-tapestry image (on top of droste-fabric)..."
    echo ""

    local base_image="$PROJECT_DIR/output-droste-fabric/droste-fabric.qcow2"
    cd "$PROJECT_DIR/packer/droste-tapestry"
    packer init .
    packer build -force -var "base_image=$base_image" droste-tapestry.pkr.hcl

    echo ""
    echo "Build complete."
    ls -lh "$PROJECT_DIR/output-droste-tapestry/droste-tapestry.qcow2"
    echo ""
    do_test tapestry
}

do_build_loom() {
    echo "Building droste-loom image (on top of droste-tapestry)..."
    echo ""

    local base_image="$PROJECT_DIR/output-droste-tapestry/droste-tapestry.qcow2"
    cd "$PROJECT_DIR/packer/droste-loom"
    packer init .
    packer build -force -var "base_image=$base_image" droste-loom.pkr.hcl

    echo ""
    echo "Build complete."
    ls -lh "$PROJECT_DIR/output-droste-loom/droste-loom.qcow2"
    echo ""
    do_test loom
}

do_build_jacquard() {
    echo "Building droste-jacquard image (on top of droste-loom)..."
    echo ""

    local base_image="$PROJECT_DIR/output-droste-loom/droste-loom.qcow2"
    cd "$PROJECT_DIR/packer/droste-jacquard"
    packer init .
    packer build -force -var "base_image=$base_image" droste-jacquard.pkr.hcl

    echo ""
    echo "Build complete."
    ls -lh "$PROJECT_DIR/output-droste-jacquard/droste-jacquard.qcow2"
    ls -lh "$PROJECT_DIR/output-droste-jacquard/droste-jacquard-diff.qcow2"
    echo ""
    do_test jacquard
}

do_build_image() {
    case "$1" in
        thread)   do_build_thread ;;
        yarn)     do_build_yarn ;;
        fabric)   do_build_fabric ;;
        tapestry) do_build_tapestry ;;
        loom)     do_build_loom ;;
        jacquard) do_build_jacquard ;;
    esac
}

# ── Tier order and chain resolution ──────────────────────────────────
ALL_TIERS=(thread yarn fabric tapestry loom jacquard)

# Return the build chain for a target tier: from the first missing
# prerequisite through the target. Always includes the target itself.
resolve_chain() {
    local target="$1"
    local chain=()
    local need_build=false
    for tier in "${ALL_TIERS[@]}"; do
        local img="$PROJECT_DIR/output-droste-${tier}/droste-${tier}.qcow2"
        if [[ ! -f "$img" ]]; then
            need_build=true
        fi
        if [[ "$need_build" == true ]]; then
            chain+=("$tier")
        fi
        [[ "$tier" == "$target" ]] && break
    done
    # Always include target (force rebuild)
    if [[ ${#chain[@]} -eq 0 ]]; then
        chain=("$target")
    fi
    echo "${chain[@]}"
}

# Return the tiers to process: all 6 for IMAGE=all, or the build
# chain (with prerequisites) for a single tier.
resolve_tiers() {
    if [[ "$IMAGE" == "all" ]]; then
        echo "${ALL_TIERS[@]}"
    else
        resolve_chain "$IMAGE"
    fi
}

# ── Container support ────────────────────────────────────────────────
ALL_CONTAINER_TIERS=(fiber sheet page tome gutenberg)

is_container_tier() {
    case "$1" in fiber|sheet|page|tome|gutenberg) return 0 ;; *) return 1 ;; esac
}

detect_container_cmd() {
    if command -v podman &>/dev/null; then
        echo podman
    elif command -v docker &>/dev/null; then
        echo docker
    else
        echo "Error: neither podman nor docker found" >&2
        exit 1
    fi
}

do_test_container() {
    local tier="$1"
    local image="droste-${tier}"
    local checkfile="$PROJECT_DIR/checks/${tier}.checks"
    local container_cmd
    container_cmd=$(detect_container_cmd)

    if [[ ! -f "$checkfile" ]]; then
        echo "Warning: no check file found: $checkfile" >&2
        return 0
    fi

    echo "droste-${tier} container test"
    echo "======================"
    echo ""

    local cname="droste-test-${tier}"
    $container_cmd rm -f "$cname" &>/dev/null || true
    $container_cmd run -d --name "$cname" "$image" sleep infinity >/dev/null

    local pass=0 fail=0 errors=()

    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        if [[ "$line" =~ ^#\  ]]; then
            echo "${line#\# }:"
            continue
        fi
        IFS=$'\t' read -r desc cmd flag <<< "$line"
        if $container_cmd exec "$cname" bash -c "$cmd" &>/dev/null; then
            echo "  + $desc"
            pass=$((pass + 1))
        else
            echo "  - FAIL: $desc"
            errors+=("$desc")
            fail=$((fail + 1))
        fi
    done < "$checkfile"

    $container_cmd rm -f "$cname" >/dev/null

    echo ""
    echo "================================"
    echo "Results: ${pass} passed, ${fail} failed"

    if [[ ${fail} -gt 0 ]]; then
        echo ""
        echo "Failures:"
        for err in "${errors[@]}"; do
            echo "  - $err"
        done
        return 1
    fi
}

do_build_container() {
    local tier="$1"
    local container_cmd
    container_cmd=$(detect_container_cmd)

    echo "Building droste-${tier} container..."
    echo ""

    $container_cmd build \
        -t "droste-${tier}" \
        -f "$PROJECT_DIR/containers/droste-${tier}/Containerfile" \
        "$PROJECT_DIR"

    echo ""
    echo "Build complete."
    $container_cmd image inspect "droste-${tier}" --format '{{.Size}}' | \
        awk '{printf "Image size: %.0f MB\n", $1/1024/1024}'
    echo ""
    do_test_container "$tier"
}

resolve_container_chain() {
    local target="$1"
    local container_cmd
    container_cmd=$(detect_container_cmd)
    local chain=()
    local need_build=false
    for tier in "${ALL_CONTAINER_TIERS[@]}"; do
        if ! $container_cmd image exists "droste-${tier}" 2>/dev/null; then
            need_build=true
        fi
        if [[ "$need_build" == true ]]; then
            chain+=("$tier")
        fi
        [[ "$tier" == "$target" ]] && break
    done
    if [[ ${#chain[@]} -eq 0 ]]; then
        chain=("$target")
    fi
    echo "${chain[@]}"
}

resolve_container_tiers() {
    local target="$1"
    if [[ "$target" == "all" ]]; then
        echo "${ALL_CONTAINER_TIERS[@]}"
    else
        resolve_container_chain "$target"
    fi
}

# ── LXC support ──────────────────────────────────────────────────────
ALL_LXC_TIERS=(hair wool felt amimono embellisher)

is_lxc_tier() {
    case "$1" in hair|wool|felt|amimono|embellisher) return 0 ;; *) return 1 ;; esac
}

do_test_lxc() {
    local tier="$1"
    local tarball="$PROJECT_DIR/output/droste-${tier}.tar.gz"
    local checkfile="$PROJECT_DIR/checks/${tier}.checks"

    if [[ ! -f "$tarball" ]]; then
        echo "Error: tarball not found: $tarball" >&2
        echo "Run '$(basename "$0") lxc build $tier' first." >&2
        exit 1
    fi

    if [[ ! -f "$checkfile" ]]; then
        echo "Warning: no check file found: $checkfile" >&2
        return 0
    fi

    echo "droste-${tier} LXC test"
    echo "======================"
    echo ""

    local test_dir
    test_dir=$(mktemp -d "/tmp/droste-test-${tier}.XXXXXX")
    tar -xf "$tarball" -C "$test_dir"

    local pass=0 fail=0 errors=()

    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        if [[ "$line" =~ ^#\  ]]; then
            echo "${line#\# }:"
            continue
        fi
        IFS=$'\t' read -r desc cmd flag <<< "$line"
        if systemd-nspawn -D "$test_dir" --quiet --pipe --register=no \
            bash -c "$cmd" &>/dev/null; then
            echo "  + $desc"
            pass=$((pass + 1))
        else
            echo "  - FAIL: $desc"
            errors+=("$desc")
            fail=$((fail + 1))
        fi
    done < "$checkfile"

    rm -rf "$test_dir"

    echo ""
    echo "================================"
    echo "Results: ${pass} passed, ${fail} failed"

    if [[ ${fail} -gt 0 ]]; then
        echo ""
        echo "Failures:"
        for err in "${errors[@]}"; do
            echo "  - $err"
        done
        return 1
    fi
}

do_build_lxc() {
    local tier="$1"

    echo "Building droste-${tier} LXC rootfs..."
    echo ""

    "$PROJECT_DIR/lxc/build-rootfs.sh" "$tier"

    echo ""
    do_test_lxc "$tier"
}

resolve_lxc_chain() {
    local target="$1"
    local chain=()
    local need_build=false
    for tier in "${ALL_LXC_TIERS[@]}"; do
        if [[ ! -f "$PROJECT_DIR/output/droste-${tier}.tar.gz" ]]; then
            need_build=true
        fi
        if [[ "$need_build" == true ]]; then
            chain+=("$tier")
        fi
        [[ "$tier" == "$target" ]] && break
    done
    if [[ ${#chain[@]} -eq 0 ]]; then
        chain=("$target")
    fi
    echo "${chain[@]}"
}

resolve_lxc_tiers() {
    local target="$1"
    if [[ "$target" == "all" ]]; then
        echo "${ALL_LXC_TIERS[@]}"
    else
        resolve_lxc_chain "$target"
    fi
}

# ── LXC command handler ──────────────────────────────────────────────
do_lxc_command() {
    local sub_cmd="all"
    local lxc_image="hair"
    local force=false

    # Parse: lxc [build|test|all] [tier] [--force]
    if [[ $# -gt 0 ]]; then
        case "$1" in
            build|test|all) sub_cmd="$1"; shift ;;
            hair|wool|felt|amimono|embellisher) lxc_image="$1"; shift ;;
        esac
    fi
    if [[ $# -gt 0 ]]; then
        case "$1" in
            hair|wool|felt|amimono|embellisher|all) lxc_image="$1"; shift ;;
        esac
    fi
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force) force=true; shift ;;
            *) echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
        esac
    done

    case "$sub_cmd" in
        build|all)
            for tier in $(resolve_lxc_tiers "$lxc_image"); do
                echo ""
                do_build_lxc "$tier"
            done
            ;;
        test)
            for tier in $(resolve_lxc_tiers "$lxc_image"); do
                echo ""
                do_test_lxc "$tier"
            done
            ;;
    esac
}

# ── Container command handler (self-contained, no SSH needed) ────────
do_container_command() {
    local sub_cmd="all"
    local container_image="all"
    local force=false

    # Parse: container [build|test|all] [tier] [--force]
    if [[ $# -gt 0 ]]; then
        case "$1" in
            build|test|all) sub_cmd="$1"; shift ;;
            fiber|sheet|page|tome|gutenberg) container_image="$1"; shift ;;
        esac
    fi
    if [[ $# -gt 0 ]]; then
        case "$1" in
            fiber|sheet|page|tome|gutenberg|all) container_image="$1"; shift ;;
        esac
    fi
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force) force=true; shift ;;
            *) echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
        esac
    done

    local container_cmd
    container_cmd=$(detect_container_cmd)
    echo "Using container engine: $container_cmd"

    case "$sub_cmd" in
        build|all)
            for tier in $(resolve_container_tiers "$container_image"); do
                echo ""
                do_build_container "$tier"
            done
            ;;
        test)
            for tier in $(resolve_container_tiers "$container_image"); do
                echo ""
                do_test_container "$tier"
            done
            ;;
    esac
}

# ── VM command handler (mirrors container command) ────────────────────
do_vm_command() {
    local sub_cmd="all"
    local vm_image="thread"
    local force=false

    # Parse: vm [prereqs|build|test|all] [tier] [--force] [--ssh-key] [--ssh-port]
    if [[ $# -gt 0 ]]; then
        case "$1" in
            prereqs|build|test|all) sub_cmd="$1"; shift ;;
            thread|yarn|fabric|tapestry|loom|jacquard) vm_image="$1"; shift ;;
        esac
    fi
    if [[ $# -gt 0 ]]; then
        case "$1" in
            thread|yarn|fabric|tapestry|loom|jacquard|all) vm_image="$1"; shift ;;
        esac
    fi
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force)    force=true; shift ;;
            --ssh-key)  SSH_KEY="$2"; shift 2 ;;
            --ssh-port) SSH_PORT="$2"; shift 2 ;;
            *)          echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
        esac
    done

    # Auto-detect SSH key if not provided
    if [[ -z "$SSH_KEY" ]]; then
        for candidate in ~/.ssh/id_ed25519.pub ~/.ssh/id_rsa.pub ~/.ssh/id_ecdsa.pub; do
            if [[ -f "$candidate" ]]; then
                SSH_KEY="$candidate"
                break
            fi
        done
        if [[ -z "$SSH_KEY" ]]; then
            echo "Error: no SSH public key found. Use --ssh-key FILE." >&2
            exit 1
        fi
        echo "Using SSH key: $SSH_KEY"
    fi

    # Set globals for resolve_tiers / check_existing_images
    IMAGE="$vm_image"
    FORCE="$force"

    case "$sub_cmd" in
        prereqs)
            do_prereqs
            ;;
        build)
            if [[ "$IMAGE" == "all" && "$FORCE" == false ]]; then
                check_existing_images
            fi
            for tier in $(resolve_tiers); do
                echo ""
                do_build_image "$tier"
            done
            ;;
        test)
            for tier in $(resolve_tiers); do
                do_test "$tier"
            done
            ;;
        all)
            do_prereqs
            if [[ "$IMAGE" == "all" && "$FORCE" == false ]]; then
                check_existing_images
            fi
            for tier in $(resolve_tiers); do
                echo ""
                do_build_image "$tier"
            done
            ;;
    esac
}

# ── Parse command and image ──────────────────────────────────────────
COMMAND="all"
IMAGE="thread"
FORCE=false
SSH_KEY=""
SSH_PORT=2222

if [[ $# -gt 0 ]]; then
    case "$1" in
        container)
            shift
            do_container_command "$@"
            exit 0
            ;;
        lxc)
            shift
            do_lxc_command "$@"
            exit 0
            ;;
        vm)
            shift
            do_vm_command "$@"
            exit 0
            ;;
        prereqs|build|test|help|-h|--help)
            COMMAND="$1"
            shift
            ;;
        thread|yarn|fabric|tapestry|loom|jacquard|all)
            IMAGE="$1"
            shift
            ;;
        fiber|sheet|page|tome|gutenberg)
            IMAGE="$1"
            shift
            ;;
        hair|wool|felt|amimono|embellisher)
            IMAGE="$1"
            shift
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
fi

if [[ $# -gt 0 ]]; then
    case "$1" in
        thread|yarn|fabric|tapestry|loom|jacquard|all)
            IMAGE="$1"
            shift
            ;;
        fiber|sheet|page|tome|gutenberg)
            IMAGE="$1"
            shift
            ;;
        hair|wool|felt|amimono|embellisher)
            IMAGE="$1"
            shift
            ;;
    esac
fi

# ── Parse global options ─────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
    case "$1" in
        --force)    FORCE=true; shift ;;
        --ssh-key)  SSH_KEY="$2"; shift 2 ;;
        --ssh-port) SSH_PORT="$2"; shift 2 ;;
        *)          echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
    esac
done

# Auto-detect SSH key if not provided (skip for container and LXC tiers)
if ! is_container_tier "$IMAGE" && ! is_lxc_tier "$IMAGE"; then
    if [[ -z "$SSH_KEY" ]]; then
        for candidate in ~/.ssh/id_ed25519.pub ~/.ssh/id_rsa.pub ~/.ssh/id_ecdsa.pub; do
            if [[ -f "$candidate" ]]; then
                SSH_KEY="$candidate"
                break
            fi
        done
        if [[ -z "$SSH_KEY" ]]; then
            echo "Error: no SSH public key found. Use --ssh-key FILE." >&2
            exit 1
        fi
        echo "Using SSH key: $SSH_KEY"
    fi
fi

# ── Guard: refuse to overwrite existing images without --force ────────
check_existing_images() {
    local found=()
    for tier in $(resolve_tiers); do
        local dir="$PROJECT_DIR/output-droste-${tier}"
        for img in "$dir"/*.qcow2; do
            [[ -f "$img" ]] && found+=("$img")
        done
    done
    if [[ ${#found[@]} -gt 0 ]]; then
        echo "Error — Image(s) present:" >&2
        for img in "${found[@]}"; do
            echo "  $img" >&2
        done
        echo "" >&2
        echo "To overwrite existing images, run: $(basename "$0") $COMMAND $IMAGE --force" >&2
        exit 1
    fi
}

# ── Main ────────────────────────────────────────────────────────────
case "$COMMAND" in
    all)
        if is_lxc_tier "$IMAGE"; then
            for tier in $(resolve_lxc_tiers "$IMAGE"); do
                echo ""
                do_build_lxc "$tier"
            done
        elif is_container_tier "$IMAGE"; then
            for tier in $(resolve_container_tiers "$IMAGE"); do
                echo ""
                do_build_container "$tier"
            done
        else
            do_prereqs
            if [[ "$IMAGE" == "all" && "$FORCE" == false ]]; then
                check_existing_images
            fi
            for tier in $(resolve_tiers); do
                echo ""
                do_build_image "$tier"
            done
        fi
        ;;
    prereqs)
        do_prereqs
        ;;
    build)
        if is_lxc_tier "$IMAGE"; then
            for tier in $(resolve_lxc_tiers "$IMAGE"); do
                echo ""
                do_build_lxc "$tier"
            done
        elif is_container_tier "$IMAGE"; then
            for tier in $(resolve_container_tiers "$IMAGE"); do
                echo ""
                do_build_container "$tier"
            done
        else
            if [[ "$IMAGE" == "all" && "$FORCE" == false ]]; then
                check_existing_images
            fi
            for tier in $(resolve_tiers); do
                echo ""
                do_build_image "$tier"
            done
        fi
        ;;
    test)
        if is_lxc_tier "$IMAGE"; then
            for tier in $(resolve_lxc_tiers "$IMAGE"); do
                echo ""
                do_test_lxc "$tier"
            done
        elif is_container_tier "$IMAGE"; then
            for tier in $(resolve_container_tiers "$IMAGE"); do
                echo ""
                do_test_container "$tier"
            done
        else
            for tier in $(resolve_tiers); do
                do_test "$tier"
            done
        fi
        ;;
    help|-h|--help)
        usage
        ;;
    *)
        echo "Unknown command: $COMMAND" >&2
        usage >&2
        exit 1
        ;;
esac
